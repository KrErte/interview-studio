<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.25.xsd">

    <changeSet id="2026-03-14-add-subscription-columns" author="claude">
        <addColumn tableName="app_users">
            <column name="subscription_id" type="VARCHAR(255)"/>
            <column name="subscription_status" type="VARCHAR(20)"/>
            <column name="subscription_ends_at" type="TIMESTAMP"/>
            <column name="subscription_created_at" type="TIMESTAMP"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>

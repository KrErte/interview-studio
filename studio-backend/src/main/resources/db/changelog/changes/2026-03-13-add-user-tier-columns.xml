<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.25.xsd">

    <changeSet id="2026-03-13-add-user-tier-columns" author="system">
        <comment>Add tier, stripe_customer_id, tier_purchased_at columns to app_users</comment>

        <addColumn tableName="app_users">
            <column name="tier" type="VARCHAR(20)" defaultValue="FREE">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <addColumn tableName="app_users">
            <column name="stripe_customer_id" type="VARCHAR(255)"/>
        </addColumn>

        <addColumn tableName="app_users">
            <column name="tier_purchased_at" type="TIMESTAMP"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
